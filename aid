  <p class="section-desc">Tu es prête ? 🎁</p>
  <br><br>
  <button id="surprise-btn" onclick="showFinale()">
    🌙 Ouvre ton cadeau, Micha ✨
  </button>
</section>

<!-- ══════════════════════════════════════════
     FINALE OVERLAY
══════════════════════════════════════════ -->
<div id="finale">
  <canvas id="finale-canvas"></canvas>
  <div class="finale-content">
    <div class="finale-big">Aïd Moubarak<br>Micha ❤️</div>
    <p class="finale-sub">
      Que cette fête soit aussi douce<br>et lumineuse que toi…
    </p>
    <span class="finale-hearts">🌙💫❤️✨🌸</span>
    <br>
    <button class="close-finale" onclick="closeFinale()">← Revenir</button>
  </div>
</div>

<!-- ══════════════════════════════════════════
     AUDIO (Web Audio API — sine wave melody)
══════════════════════════════════════════ -->

<script>
/* ─────────────────────────────────────────────
   MUSIC — gentle generative melody
───────────────────────────────────────────── */
let audioCtx = null;
let musicPlaying = false;
let melodyTimeout = null;

const notes = {
  C4: 261.63, D4: 293.66, E4: 329.63, F4: 349.23,
  G4: 392.00, A4: 440.00, B4: 493.88,
  C5: 523.25, D5: 587.33, E5: 659.25, G5: 783.99, A5: 880.00
};

const melodyPattern = [
  ['E4',0.5],['G4',0.5],['A4',1],['G4',0.5],['E4',0.5],
  ['C4',1],['D4',0.5],['E4',0.5],['G4',1.5],
  ['A4',0.5],['G4',0.5],['F4',1],['E4',0.5],['D4',0.5],
  ['E4',2],
  ['E5',0.5],['D5',0.5],['C5',1],['A4',0.5],['G4',0.5],
  ['A4',1.5],['B4',0.5],['C5',1],
  ['G4',0.5],['A4',0.5],['B4',1],['C5',0.5],['B4',0.5],
  ['A4',2.5]
];

let melodyIndex = 0;

function playNote(freq, startTime, duration, masterGain) {
  if (!audioCtx) return;
  const osc = audioCtx.createOscillator();
  const gainNode = audioCtx.createGain();
  osc.connect(gainNode);
  gainNode.connect(masterGain);
  osc.type = 'sine';
  osc.frequency.setValueAtTime(freq, startTime);
  gainNode.gain.setValueAtTime(0, startTime);
  gainNode.gain.linearRampToValueAtTime(0.18, startTime + 0.04);
  gainNode.gain.linearRampToValueAtTime(0.12, startTime + duration * 0.5);
  gainNode.gain.linearRampToValueAtTime(0, startTime + duration - 0.05);
  osc.start(startTime);
  osc.stop(startTime + duration);
}

let masterGainNode = null;

function scheduleMelody() {
  if (!musicPlaying || !audioCtx) return;
  const now = audioCtx.currentTime;
  let t = now;
  for (let i = 0; i < 6; i++) {
    const [noteName, dur] = melodyPattern[melodyIndex % melodyPattern.length];
    playNote(notes[noteName], t, dur * 0.52, masterGainNode);
    t += dur * 0.52;
    melodyIndex++;
  }
  melodyTimeout = setTimeout(scheduleMelody, (t - now - 0.05) * 1000);
}

function toggleMusic() {
  const btn = document.getElementById('music-btn');
  const label = document.getElementById('music-label');
  if (!musicPlaying) {
    if (!audioCtx) {
      audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      masterGainNode = audioCtx.createGain();
      masterGainNode.gain.setValueAtTime(0.45, audioCtx.currentTime);
      // Add reverb-like effect with a simple delay
      const delay = audioCtx.createDelay(0.8);
      delay.delayTime.value = 0.35;
      const delayGain = audioCtx.createGain();
      delayGain.gain.value = 0.25;
      masterGainNode.connect(delay);
      delay.connect(delayGain);
      delayGain.connect(audioCtx.destination);
      masterGainNode.connect(audioCtx.destination);
    }
    musicPlaying = true;
    scheduleMelody();
    btn.classList.add('playing');
    label.textContent = 'En pause';
  } else {
    musicPlaying = false;
    clearTimeout(melodyTimeout);
    btn.classList.remove('playing');
    label.textContent = 'Jouer la musique';
  }
}

/* ─────────────────────────────────────────────
   PARTICLES BACKGROUND
───────────────────────────────────────────── */
const canvas = document.getElementById('particles-canvas');
const ctx = canvas.getContext('2d');
let particles = [];

function resizeCanvas() {
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
}
resizeCanvas();
window.addEventListener('resize', resizeCanvas);

const particleEmojis = ['✦','✧','·','*','°'];
const particleColors = ['rgba(244,167,185,', 'rgba(212,168,67,', 'rgba(176,143,192,', 'rgba(240,208,128,'];

class Particle {
  constructor() { this.reset(); }
  reset() {
    this.x = Math.random() * canvas.width;
    this.y = Math.random() * canvas.height;
    this.size = Math.random() * 3 + 1;
    this.speedX = (Math.random() - 0.5) * 0.4;
    this.speedY = (Math.random() - 0.5) * 0.3 - 0.15;
    this.color = particleColors[Math.floor(Math.random() * particleColors.length)];
    this.alpha = Math.random() * 0.5 + 0.1;
    this.pulse = Math.random() * Math.PI * 2;
    this.pulseSpeed = 0.02 + Math.random() * 0.02;
  }
  update() {
    this.x += this.speedX;
    this.y += this.speedY;
    this.pulse += this.pulseSpeed;
    if (this.y < -10 || this.x < -10 || this.x > canvas.width + 10) this.reset();
  }
  draw() {
    const a = this.alpha * (0.7 + 0.3 * Math.sin(this.pulse));
    ctx.fillStyle = `${this.color}${a})`;
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
    ctx.fill();
  }
}

for (let i = 0; i < 90; i++) particles.push(new Particle());

function animateParticles() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  particles.forEach(p => { p.update(); p.draw(); });
  requestAnimationFrame(animateParticles);
}
animateParticles();

/* ─────────────────────────────────────────────
   FLOATING LANTERNS
───────────────────────────────────────────── */
const lanternSymbols = ['🪔','🌟','✨','💫','🌙','🪷','🌸'];
const container = document.getElementById('lanterns-container');

function spawnLantern() {
  const el = document.createElement('div');
  el.className = 'floating-lantern';
  el.textContent = lanternSymbols[Math.floor(Math.random() * lanternSymbols.length)];
  const left = Math.random() * 95;
  const duration = 12 + Math.random() * 14;
  const delay = Math.random() * -18;
  const size = 18 + Math.random() * 18;
  el.style.cssText = `left:${left}vw; font-size:${size}px; animation-duration:${duration}s; animation-delay:${delay}s;`;
  container.appendChild(el);
  setTimeout(() => el.remove(), (duration + Math.abs(delay)) * 1000 + 2000);
}

for (let i = 0; i < 14; i++) spawnLantern();
setInterval(spawnLantern, 3500);

/* ─────────────────────────────────────────────
   TYPEWRITER MESSAGE
───────────────────────────────────────────── */
const fullMessage = `Aïd Moubarak ma chère Micha ❤️\n\nEn ce jour spécial, je te souhaite tout le bonheur du monde, de la joie et une vie remplie de sourires.\n\nQue cette fête soit aussi douce et lumineuse que toi. Merci d'être dans ma vie, tu rends tout plus beau.`;

let typewriterDone = false;
let typewriterIndex = 0;
const typeTarget = document.getElementById('typewriter-text');

function typewriterTick() {
  if (typewriterIndex >= fullMessage.length) {
    const cursor = typeTarget.querySelector('.typewriter-line');
    if (cursor) setTimeout(() => cursor.style.display = 'none', 1500);
    return;
  }
  const char = fullMessage[typewriterIndex];
  if (char === '\n') {
    typeTarget.appendChild(document.createElement('br'));
    if (fullMessage[typewriterIndex+1] === '\n') {
      typeTarget.appendChild(document.createElement('br'));
      typewriterIndex++;
    }
  } else {
    let span = typeTarget.querySelector('.typewriter-line');
    if (!span) {
      span = document.createElement('span');
      span.className = 'typewriter-line';
      typeTarget.appendChild(span);
    }
    span.remove();
    typeTarget.appendChild(document.createTextNode(char));
    const newSpan = document.createElement('span');
    newSpan.className = 'typewriter-line';
    newSpan.textContent = '|';
    typeTarget.appendChild(newSpan);
  }
  typewriterIndex++;
  setTimeout(typewriterTick, char === '.' || char === '!' || char === '?' ? 220 : char === ',' ? 120 : 32);
}

/* ─────────────────────────────────────────────
   INTERSECTION OBSERVER — trigger on scroll
───────────────────────────────────────────── */
const msgCard = document.getElementById('message-card');
const msgObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting && !typewriterDone) {
      typewriterDone = true;
      msgCard.classList.add('visible');
      setTimeout(typewriterTick, 600);
    }
  });
}, { threshold: 0.3 });
msgObserver.observe(msgCard);

/* ─────────────────────────────────────────────
   COUNTDOWN (depuis début Aïd)
───────────────────────────────────────────── */
const eidStart = new Date();
eidStart.setHours(0, 0, 0, 0);

function updateCountdown() {
  const now = new Date();
  const diff = Math.floor((now - eidStart) / 1000);
  const h = Math.floor(diff / 3600);
  const m = Math.floor((diff % 3600) / 60);
  const s = diff % 60;
  document.getElementById('cd-h').textContent = String(h).padStart(2,'0');
  document.getElementById('cd-m').textContent = String(m).padStart(2,'0');
  document.getElementById('cd-s').textContent = String(s).padStart(2,'0');
}
updateCountdown();
setInterval(updateCountdown, 1000);



/* ─────────────────────────────────────────────
   FIREWORKS / FINALE
───────────────────────────────────────────── */
const finale = document.getElementById('finale');
const fCanvas = document.getElementById('finale-canvas');
const fCtx = fCanvas.getContext('2d');
let fireworksRunning = false;
let fParticles = [];

function resizeFCanvas() {
  fCanvas.width = window.innerWidth;
  fCanvas.height = window.innerHeight;
}

class Firework {
  constructor() { this.reset(); }
  reset() {
    this.x = Math.random() * fCanvas.width;
    this.y = Math.random() * fCanvas.height * 0.6;
    this.particles = [];
    const count = 50 + Math.floor(Math.random() * 40);
    const hues = [
      `hsl(${Math.random()*30+330},100%,75%)`,  // pinks
      `hsl(${Math.random()*20+40},100%,70%)`,   // golds
      `hsl(${Math.random()*30+270},70%,75%)`,   // purples
      'white'
    ];
    const color = hues[Math.floor(Math.random() * hues.length)];
    for (let i = 0; i < count; i++) {
      const angle = (i / count) * Math.PI * 2;
      const speed = 2 + Math.random() * 5;
      this.particles.push({
        x: this.x, y: this.y,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        alpha: 1,
        color,
        size: 2 + Math.random() * 2
      });
    }
    this.done = false;
  }
  update() {
    let alive = 0;
    this.particles.forEach(p => {
      p.x += p.vx;
      p.y += p.vy;
      p.vy += 0.07;
      p.vx *= 0.97;
      p.alpha -= 0.016;
      if (p.alpha > 0) alive++;
    });
    if (alive === 0) this.done = true;
  }
  draw() {
    this.particles.forEach(p => {
      if (p.alpha <= 0) return;
      fCtx.globalAlpha = p.alpha;
      fCtx.fillStyle = p.color;
      fCtx.beginPath();
      fCtx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      fCtx.fill();
    });
  }
}

let fireworkPool = [];
let fwInterval;

function fireworkLoop() {
  fCtx.clearRect(0, 0, fCanvas.width, fCanvas.height);
  fCtx.globalAlpha = 1;
  fireworkPool = fireworkPool.filter(f => !f.done);
  fireworkPool.forEach(f => { f.update(); f.draw(); });
}

function showFinale() {
  finale.classList.add('active');
  resizeFCanvas();
  fireworksRunning = true;
  fwInterval = setInterval(() => {
    if (fireworkPool.length < 6) fireworkPool.push(new Firework());
  }, 350);
  const fwRaf = () => {
    if (!fireworksRunning) return;
    fireworkLoop();
    requestAnimationFrame(fwRaf);
  };
  requestAnimationFrame(fwRaf);
}

function closeFinale() {
  finale.classList.remove('active');
  fireworksRunning = false;
  clearInterval(fwInterval);
  fireworkPool = [];
  fCtx.clearRect(0, 0, fCanvas.width, fCanvas.height);
}

window.addEventListener('resize', () => {
  resizeCanvas();
  if (fireworksRunning) resizeFCanvas();
});
</script>
